      </column>
      <column caption='AGE GROUP ' datatype='string' name='[Calculation_0095664284426240]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ABS([DAYS_BIRTH])/365 &lt; 30 THEN &quot;Young&quot;&#13;&#10;ELSEIF ABS([DAYS_BIRTH])/365 &lt;= 50 THEN &quot;Mid Age&quot;&#13;&#10;ELSE &quot;Senior&quot;&#13;&#10;END' />
      </column>
      <column caption='MALE CUSTOMER' datatype='integer' name='[Calculation_1110515426357248]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [CODE_GENDER] = &apos;M&apos; THEN [ID] END' />
      </column>
      <column caption='FEMALE CUSTOMER ' datatype='integer' name='[Calculation_1110515426574337]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [CODE_GENDER] = &apos;F&apos; THEN [ID] END' />
      </column>
