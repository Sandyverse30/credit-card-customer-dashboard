      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0091543569858561] / TOTAL([Calculation_0091543569858561])'>
          <table-calc ordering-type='Table' />
        </calculation>
      </column>
      <column caption='TOTAL CUSTOMER' datatype='integer' datatype-customized='true' name='[Calculation_0091543569858561]' role='measure' type='quantitative'>
